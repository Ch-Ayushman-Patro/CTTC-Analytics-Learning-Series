        <calculation class='tableau' formula='IF SUM([Profit]) &gt; 20000 THEN &apos;HIGH PROFIT&apos;&#13;&#10;ELSE &apos;LOW PROFIT&apos;&#13;&#10;&#13;&#10;END' />
